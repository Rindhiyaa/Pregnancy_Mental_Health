# ============================================================
# PPD Risk Insight — Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate JWT secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
DB_USER=mluser
DB_PASS=mlpass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ml_db

# ── JWT Secrets (CHANGE THESE — use different values for each) ──
JWT_SECRET_KEY=your-access-token-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-here-different-from-above

# ── Environment ──────────────────────────────────────────────
# Set to 'production' when deploying
ENVIRONMENT=development

# ── CORS — allowed frontend origins ─────────────────────────
# Add your frontend URL here (comma-separated, no spaces)
# If frontend runs on a different machine, add its IP too:
#   e.g. http://192.168.1.50:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000

# ── Trusted Hosts ────────────────────────────────────────────
TRUSTED_HOSTS=localhost,127.0.0.1

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Default password for new users created by admin ─────────
DEFAULT_USER_PASSWORD=TempPass123!

# ── Email (Gmail SMTP) ───────────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME=PPD Risk Insight
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_RECIPIENT=your@gmail.com
