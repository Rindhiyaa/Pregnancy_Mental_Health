# JWT Configuration
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Use DIFFERENT keys for access and refresh tokens!
JWT_SECRET_KEY=your-access-token-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-here-min-32-chars-DIFFERENT

# Environment
ENVIRONMENT=development  # Set to 'production' in production

# CORS Origins (comma-separated, no spaces)
# Development default includes common local ports
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Trusted Hosts (comma-separated, no spaces)
# For TrustedHostMiddleware - prevents host header attacks
# Development default:
TRUSTED_HOSTS=localhost,127.0.0.1
# Production example (Render):
# TRUSTED_HOSTS=ppd-backend.onrender.com,your-custom-domain.com

# Database (if using external database)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# API Configuration
# API_HOST=0.0.0.0
# API_PORT=8000
