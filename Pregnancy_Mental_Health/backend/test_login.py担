
import sys
import os
sys.path.append(os.getcwd())

from app.database import SessionLocal
from app import models
from app.security import verify_password, hash_password

def test_manual_login(email, password):
    db = SessionLocal()
    try:
        user = db.query(models.User).filter(models.User.email == email).first()
        if not user:
            print(f"User {email} NOT FOUND")
            return
        
        is_valid = verify_password(password, user.hashed_password)
        print(f"Login for {email}: {'SUCCESS' if is_valid else 'FAILED'}")
        print(f"Hash in DB: {user.hashed_password}")
        
        # Test what a new hash looks like
        new_hash = hash_password(password)
        print(f"New hash for '{password}': {new_hash}")
        
    finally:
        db.close()

if __name__ == "__main__":
    test_manual_login("admin@hospital.com", "Admin@123")
    test_manual_login("doctor1@hospital.com", "Doctor@123")
    test_manual_login("nurse1@hospital.com", "Nurse@123")
